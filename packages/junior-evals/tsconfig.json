{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["../junior/src/*"],
      "@junior-tests/*": ["../junior/tests/*"]
    }
  },
  "include": ["evals/**/*.ts", "tests/**/*.ts"]
}
